# Discord bot token (required)
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token

# Jules API key (required)
JULES_API_KEY=your-jules-api-key

# Path to access policy JSON (optional, defaults to ./access.json)
# ACCESS_JSON=/absolute/path/to/access.json

# Where session pointers (channelId → sessionId) are persisted
# (optional, defaults to ./state)
# STATE_DIR=/absolute/path/to/state

# Jules context window size for the progress bar embed
# (optional, defaults to 1_000_000)
# CONTEXT_WINDOW=200000

# Max bytes per Discord attachment we'll fetch and forward
# (optional, defaults to 25 MiB)
# MAX_ATTACHMENT_BYTES=26214400

# Max bytes per IMAGE attachment (Jules API caps images at 5MB)
# Larger images are rejected with a clear error before upload.
# (optional, defaults to 5 MiB)
# MAX_IMAGE_BYTES=5242880

# SDK permission mode. Options:
#   bypassPermissions  — no permission checks; bot can run any tool. (DEFAULT)
#   acceptEdits        — auto-approve file edits, block other tools (Bash, etc.)
#   plan               — planning only, no execution
#   default            — interactive prompt (DOES NOT WORK in this bot context — will hang)
# SECURITY: 'bypassPermissions' gives anyone authorized in access.json arbitrary
# shell access on the host. Use 'acceptEdits' to limit blast radius if you don't
# need full system access.
# PERMISSION_MODE=bypassPermissions

# Close per-channel agents after this many minutes of inactivity. The session
# pointer persists, so the next message resumes the conversation (paying an
# ~8s cold start once). Set to 0 to disable idle eviction (agents live forever).
# (optional, defaults to 30)
# IDLE_MINUTES=30

# Hard cap on simultaneously-live agents. When exceeded and a new channel
# wants an agent, the LRU non-busy agent is evicted. If every agent is mid-turn,
# the cap is exceeded temporarily; idle eviction trims back. Each agent costs
# ~500-600MB resident, so size this to your host's memory.
# (optional, defaults to 8)
# MAX_ACTIVE_AGENTS=8
