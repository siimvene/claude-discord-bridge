# Discord bot token (required)
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token

# Path to access policy JSON (optional, defaults to ./access.json)
# ACCESS_JSON=/absolute/path/to/access.json

# Where session pointers (channelId → sessionId) are persisted
# (optional, defaults to ./state)
# STATE_DIR=/absolute/path/to/state

# Claude context window size for the progress bar embed
# (optional, defaults to 1_000_000)
# CONTEXT_WINDOW=200000

# Max bytes per Discord attachment we'll fetch and forward
# (optional, defaults to 25 MiB)
# MAX_ATTACHMENT_BYTES=26214400
