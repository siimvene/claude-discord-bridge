{
  "_comment": "Per-channel access policy. Channel IDs are Discord snowflakes (right-click channel → Copy Channel ID, requires Developer Mode).",
  "groups": {
    "1234567890123456789": {
      "_comment": "Private DM-style channel — only this user, replies even without @mention.",
      "allowFrom": ["111111111111111111"],
      "requireMention": false
    },
    "9876543210987654321": {
      "_comment": "Shared channel — multiple users, only respond when explicitly @mentioned or replied-to.",
      "allowFrom": ["111111111111111111", "222222222222222222"],
      "requireMention": true
    },
    "5555555555555555555": {
      "_comment": "Open channel — anyone in the channel can talk to the bot. Be careful: this gives them shell access on the host (see SECURITY in README).",
      "requireMention": true
    }
  }
}
